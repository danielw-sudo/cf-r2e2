{
	"name": "r2-e2",
	"version": "2.0.0",
	"description": "Private R2 asset management dashboard",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dashboard",
		"dist",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsup src/index.ts --format cjs,esm --dts && cp -R ../dashboard/dist/spa/ dashboard/ && cp ../../README.md . && cp ../../LICENSE .",
		"lint": "npx @biomejs/biome check src/ tests/ || (npx @biomejs/biome check --write src/ tests/; exit 1)",
		"test": "npx vitest run --config tests/vitest.config.mts",
		"package": "npm run build && npm pack",
		"publish-npm": "npm publish",
		"seed:local": "node scripts/seed.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"cloudflare",
		"worker",
		"workers",
		"serverless",
		"cloudflare r2",
		"r2",
		"r2 storage",
		"drive",
		"google drive",
		"ui",
		"cf",
		"typescript",
		"npm",
		"package",
		"cjs",
		"esm",
		"umd",
		"typed"
	],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.38",
		"@cloudflare/workers-types": "^4.20260329.1",
		"@types/node": "^22.10.1",
		"@vitest/coverage-istanbul": "^3.2.3",
		"hono": "^4.6.15",
		"tsup": "^8.3.5",
		"typescript": "^5.7.2",
		"vitest": "^3.2.3",
		"wrangler": "^4.78.0"
	},
	"dependencies": {
		"@hono/cloudflare-access": "^0.2.0",
		"chanfana": "^2.5.1",
		"postal-mime": "^2.3.2",
		"zod": "^3.24.1"
	}
}
